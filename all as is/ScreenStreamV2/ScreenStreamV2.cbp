		<Linker>
			<Add option="-lgdi32" />
			<Add option="-lmswsock" />
			<Add option="-lws2_32" />
			<Add option="-lole32" />
			<Add option="-luser32" />
			<Add option="-lgdiplus" />
		</Linker>
		<Unit filename="main.cpp" />
		<Extensions>
